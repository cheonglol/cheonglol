                  {[1, 2, 3, 4, 5].map((i) => (
                    <span class={`bar ${i > level ? "dim" : ""}`} />
                  ))}
                </span>
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </section>

  <SectionDivider />

  <section>
    <h2>Notes & Extras</h2>
    <article class="card">
      <h3>Infrastructure & Homelab</h3>
